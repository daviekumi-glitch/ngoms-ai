rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only collections (content managed by admin panel)
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /app_banner/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /courses/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /quizzes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /plans/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coupons/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /badges/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /faqs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /features/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User-creatable collections (readable by all, writable by authenticated users)
    match /flashcard_decks/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /documents/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /notifications/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin-only collections
    match /payments/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /system_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Contact form (anyone can create, only admin can read)
    match /contact_messages/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // User profiles (each user owns their profile)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
